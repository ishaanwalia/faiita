generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  GB_MEMBER   // Governing Body Member
}

enum OfficeBearerRole {
  PRESIDENT
  SR_VP
  VP
  SECRETARY
  TREASURER
  JOINT_SECRETARY
  JOINT_TREASURER
}

// ─── USER (for GB member logins only) ──────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    @db.Text
  role          UserRole  @default(GB_MEMBER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── OFFICE BEARER (Leadership Team) ───────────────────

model OfficeBearer {
  id          String           @id @default(cuid())
  role        OfficeBearerRole
  name        String
  phone       String
  email       String
  tenureStart DateTime
  tenureEnd   DateTime?
  photoUrl    String?
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── GOVERNING BODY MEMBER (State Representatives) ─────

model GoverningBodyMember {
  id              String   @id @default(cuid())
  state           String
  name            String
  associationName String
  phone           String
  email           String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── STATE ASSOCIATION (25 States) ─────────────────────

model StateAssociation {
  id              String   @id @default(cuid())
  state           String   @unique
  city            String
  associationName String
  presidentName   String
  memberCount     Int      @default(0)
  phone           String
  email           String
  website         String?
  logoUrl         String?
  description     String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── NEWS ARTICLE ──────────────────────────────────────

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  image       String?
  category    String   @default("news")
  author      String?
  publishedAt DateTime @default(now())
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── EVENT ─────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String    @db.Text
  image       String?
  startDate   DateTime
  endDate     DateTime?
  location    String
  isOnline    Boolean   @default(false)
  meetingLink String?
  status      String    @default("upcoming") // upcoming | past | cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── CONTACT LEAD (public contact form submissions) ────

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}